<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05020A">

    <View
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="@android:drawable/screen_background_dark_transparent"
        android:alpha="0.6"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="12dp"
        app:cardBackgroundColor="#90000000"
        app:cardCornerRadius="40dp"
        app:strokeColor="#9D00FF"
        app:strokeWidth="8dp"
        app:cardElevation="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CORETUNER MAX // ULTRA VIP"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                app:cardBackgroundColor="#B31A1030"
                app:cardCornerRadius="30dp"
                app:strokeColor="#651FFF"
                app:strokeWidth="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txt_shizuku"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="> CLIQUE AQUI P/ ABRIR SHIZUKU"
                        android:textColor="#FF1744"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_cpu_speed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1,35 GHz"
                        android:textColor="#00FF41"
                        android:textSize="68sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_ajuste_fino"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:text="AJUSTE\nFINO"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="#CC4D0000"
                    app:strokeColor="#FF1744"
                    app:strokeWidth="6dp"
                    app:cornerRadius="30dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_economia"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="6dp"
                    android:text="ECONOMIA"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="#CC003300"
                    app:strokeColor="#00E676"
                    app:strokeWidth="6dp"
                    app:cornerRadius="30dp" />
            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:columnCount="2"
                android:layout_marginTop="10dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_performance"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="PERF"
                    app:backgroundTint="#CC331900"
                    app:strokeColor="#FF9100"
                    app:strokeWidth="5dp"
                    app:cornerRadius="25dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_bateria"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="BATERIA"
                    app:backgroundTint="#CC001A33"
                    app:strokeColor="#00B0FF"
                    app:strokeWidth="5dp"
                    app:cornerRadius="25dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_touch"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="TOUCH"
                    app:backgroundTint="#CC260033"
                    app:strokeColor="#D500F9"
                    app:strokeWidth="5dp"
                    app:cornerRadius="25dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_fps"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="FPS"
                    app:backgroundTint="#CC002613"
                    app:strokeColor="#00FF8C"
                    app:strokeWidth="5dp"
                    app:cornerRadius="25dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_sistema"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="SYSTEM"
                    app:backgroundTint="#CC333300"
                    app:strokeColor="#FFEA00"
                    app:strokeWidth="5dp"
                    app:cornerRadius="25dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_zram"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="ZRAM"
                    app:backgroundTint="#CC1A0033"
                    app:strokeColor="#651FFF"
                    app:strokeWidth="5dp"
                    app:cornerRadius="25dp" />
            </GridLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MORAES YAROSNI // VIP 2026"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="10dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
