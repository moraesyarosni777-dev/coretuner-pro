<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F13">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CORETUNER MAX // VIP"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="10dp"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/border_neon_green"
            android:orientation="vertical"
            android:padding="10dp"
            android:gravity="center">

            <TextView
                android:id="@+id/txt_shizuku"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="> CLIQUE AQUI P/ ABRIR SHIZUKU"
                android:textColor="#FF0000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_gravity="start" />

            <TextView
                android:id="@+id/txt_cpu_speed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1,35 GHz"
                android:textColor="#00FF41"
                android:textSize="48sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MEM: 68%"
                    android:textColor="#B026FF"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DTC: 0,31"
                    android:textColor="#3D7DFF"
                    android:textSize="12sp"
                    android:layout_alignParentEnd="true" />
            </RelativeLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="> CONTROLES MESTRES"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_ajuste_fino"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:text="AJUSTE FINO\nEXTREMO 🚀"
                android:textColor="#FF0000"
                android:backgroundTint="#1A1A1A"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btn_economia"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_weight="1"
                android:text="ECONOMIA\nEXTREMA 🔋"
                android:textColor="#00FF00"
                android:backgroundTint="#1A1A1A"
                android:layout_margin="4dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="> CONTROLES INDIVIDUAIS"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="10dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3">

            <Button
                android:id="@+id/btn_performance"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:text="PERFORMANCE"
                android:textColor="#FF5E00"
                android:backgroundTint="#1A1A1A"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btn_bateria"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:text="BATERIA"
                android:textColor="#00A2FF"
                android:backgroundTint="#1A1A1A"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btn_touch"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:text="TOUCH"
                android:textColor="#B026FF"
                android:backgroundTint="#1A1A1A"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btn_fps"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:text="FPS MAX"
                android:textColor="#00FF8C"
                android:backgroundTint="#1A1A1A"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btn_sistema"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:text="SISTEMA"
                android:textColor="#FFD000"
                android:backgroundTint="#1A1A1A"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/btn_zram"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:text="ZRAM/MEM"
                android:textColor="#4C00FF"
                android:backgroundTint="#1A1A1A"
                android:layout_margin="4dp" />
        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Moraes Yarosni VIP"
            android:textColor="#BBBBBB"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>
