                <?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F111A"> <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:drawable/screen_background_dark_transparent"
        android:alpha="0.5" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="10dp"
        app:cardBackgroundColor="#1AFFFFFF" 
        app:cardCornerRadius="35dp"
        app:strokeColor="#4DFFFFFF" 
        app:strokeWidth="7dp"
        app:cardElevation="15dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CORETUNER MAX // ULTRA VIP"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="15dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                app:cardBackgroundColor="#33FFFFFF"
                app:cardCornerRadius="25dp"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/txt_shizuku"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="> SHIZUKU VINCULADO COM SUCESSO <"
                        android:textColor="#00FF41"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_cpu_speed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1,35 GHz"
                        android:textColor="#FFFFFF"
                        android:textSize="70sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:columnCount="2"
                android:rowCount="4"
                android:layout_marginTop="15dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_ajuste_fino"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="AJUSTE\nFINO"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#40FFFFFF"
                    app:strokeColor="#FF1744"
                    app:strokeWidth="6dp"
                    app:cornerRadius="25dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_economia"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="ECONOMIA"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#40FFFFFF"
                    app:strokeColor="#00FF41"
                    app:strokeWidth="6dp"
                    app:cornerRadius="25dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_performance"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="PERF"
                    app:backgroundTint="#40FFFFFF"
                    app:strokeColor="#FF9100"
                    app:strokeWidth="5dp"
                    app:cornerRadius="20dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_bateria"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="BATERIA"
                    app:backgroundTint="#40FFFFFF"
                    app:strokeColor="#00B0FF"
                    app:strokeWidth="5dp"
                    app:cornerRadius="20dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_touch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="TOUCH"
                    app:backgroundTint="#40FFFFFF"
                    app:strokeColor="#D500F9"
                    app:strokeWidth="5dp"
                    app:cornerRadius="20dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_fps"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="FPS"
                    app:backgroundTint="#40FFFFFF"
                    app:strokeColor="#00FF8C"
                    app:strokeWidth="5dp"
                    app:cornerRadius="20dp" />

            </GridLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MORAES YAROSNI // VIP 2026"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="10dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>                
