<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050A14"
    android:padding="10dp"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_outer_frame"
        android:padding="16dp"
        android:weightSum="10">

        <!-- TÍTULO -->
        <TextView
            style="@style/NeonTextCyan"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="CORETUNER MAX // ULTRA VIP"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <!-- PAINEL SHIZUKU -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2.5"
            android:orientation="vertical"
            android:background="@drawable/bg_panel_shizuku"
            android:padding="15dp"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <TextView
                style="@style/NeonTextGreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SHIZUKU VINCULADO COM SUCESSO"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                style="@style/NeonTextCyan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AO CLICAR NAS CONFIGURAÇÕES\nABAIXO LIMITADORES DE\nHARDWARE SERÃO DESATIVADOS\nATIVANDO EFEITOS IMEDIATOS"
                android:textAlignment="center"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- GRID DE BOTÕES: Estica cada linha para ocupar o espaço central -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="5.5"
            android:columnCount="2"
            android:rowCount="4">

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="5dp" android:background="@drawable/bg_item_cyan" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛠️" android:textSize="32sp" android:layout_marginEnd="6dp"/>
                <TextView style="@style/NeonTextCyan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AJUSTE FINO" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="5dp" android:background="@drawable/bg_item_cyan" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📉" android:textSize="32sp" android:layout_marginEnd="6dp"/>
                <TextView style="@style/NeonTextCyan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ECONOMIA" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="5dp" android:background="@drawable/bg_item_green" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡" android:textSize="32sp" android:layout_marginEnd="6dp"/>
                <TextView style="@style/NeonTextGreen" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PERFORMANCE" android:textSize="11sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="5dp" android:background="@drawable/bg_item_green" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔋" android:textSize="32sp" android:layout_marginEnd="6dp"/>
                <TextView style="@style/NeonTextGreen" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BATERIA" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="5dp" android:background="@drawable/bg_item_green" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👆" android:textSize="32sp" android:layout_marginEnd="6dp"/>
                <TextView style="@style/NeonTextGreen" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOUCH" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="5dp" android:background="@drawable/bg_item_green" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎮" android:textSize="32sp" android:layout_marginEnd="6dp"/>
                <TextView style="@style/NeonTextGreen" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FPS MAX" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="5dp" android:background="@drawable/bg_item_cyan" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🖥️" android:textSize="32sp" android:layout_marginEnd="6dp"/>
                <TextView style="@style/NeonTextCyan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SISTEMA" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="5dp" android:background="@drawable/bg_item_cyan" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧠" android:textSize="32sp" android:layout_marginEnd="6dp"/>
                <TextView style="@style/NeonTextCyan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ZRAM" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>

        </GridLayout>

        <!-- RODAPÉ -->
        <TextView
            style="@style/NeonTextCyan"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="MORAES YAROSNI // VIP 2026\nby Yarosni"
            android:textAlignment="center"
            android:textSize="14sp"
            android:textStyle="bold"/>

    </LinearLayout>
</LinearLayout>
