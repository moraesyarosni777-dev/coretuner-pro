<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0B0D">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/brushed_steel_bg"
        android:alpha="0.6"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CORETUNER PRO MAX // VIP"
            android:textColor="#00E5FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/dateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MON, MAY 11 2026"
            android:textColor="#446688"
            android:textSize="10sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mainCard"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="15dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#CC10151A"
            app:strokeColor="#3300E5FF"
            app:strokeWidth="1dp"
            app:cardElevation="15dp">
            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="20dp">

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AGUARDANDO INJEÇÃO..."
                    android:textColor="#32CD32"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/coreValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.20"
                        android:textColor="#00FF41"
                        android:textSize="48sp"
                        android:fontFamily="monospace" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GHz"
                        android:textColor="#00FF41"
                        android:layout_marginLeft="5dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/ramValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:text="RAM_LOAD: 42%"
                    android:textColor="#D500F9"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/dtcValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentRight="true"
                    android:text="DTC_LINK: 0.12"
                    android:textColor="#AA00FF"
                    android:fontFamily="monospace" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:columnCount="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/performanceButton"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="OTIMIZAR\nEXTREMO ⚡"
                android:backgroundTint="#1A1F26"
                android:textColor="#FF5722"
                app:cornerRadius="15dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/batteryButton"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="ECONOMIA\nFRIO ❄️"
                android:backgroundTint="#1A1F26"
                android:textColor="#00BCD4"
                app:cornerRadius="15dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cacheButton"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="LIMPAR CACHE"
                android:backgroundTint="#0F1F0F"
                android:textColor="#32CD32"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/touchButton"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="OTIMIZAR TOUCH"
                android:backgroundTint="#1F0F1F"
                android:textColor="#D500F9"
                app:cornerRadius="12dp" />
        </GridLayout>

        <TextView
            android:id="@+id/signature3D"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center"
            android:text="Moraes Yarosni VIP"
            android:textColor="#32CD32"
            android:textSize="18sp"
            android:textStyle="italic" />

    </LinearLayout>
</RelativeLayout>
