<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050505"
    android:padding="16dp"
    android:weightSum="100">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="8"
        android:text="CORETUNER MAX // ULTRA VIP"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="24"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#00000000"
        app:cardCornerRadius="20dp"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="3dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/txt_shizuku"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SHIZUKU VINCULADO COM SUCESSO"
                android:textColor="#00FF41"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_cpu_speed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1,35 GHz"
                android:textColor="#FFFFFF"
                android:textSize="60sp"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="18"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_ajuste_fino"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#00000000"
            app:cardCornerRadius="16dp"
            app:strokeColor="#FF1744"
            app:strokeWidth="3dp"
            app:cardElevation="0dp">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="AJUSTE FINO" android:textColor="#FF1744" android:textStyle="bold" android:gravity="center" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_economia"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#00000000"
            app:cardCornerRadius="16dp"
            app:strokeColor="#00FF41"
            app:strokeWidth="3dp"
            app:cardElevation="0dp">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="ECONOMIA" android:textColor="#00FF41" android:textStyle="bold" android:gravity="center" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="40"
        android:orientation="vertical"
        android:weightSum="3">

        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <com.google.android.material.card.MaterialCardView android:id="@+id/btn_performance" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#00000000" app:cardCornerRadius="16dp" app:strokeColor="#FF9100" app:strokeWidth="2dp" app:cardElevation="0dp">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="PERFORMANCE" android:textColor="#FF9100" android:textStyle="bold" android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:id="@+id/btn_bateria" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#00000000" app:cardCornerRadius="16dp" app:strokeColor="#2979FF" app:strokeWidth="2dp" app:cardElevation="0dp">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="BATERIA" android:textColor="#2979FF" android:textStyle="bold" android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:layout_marginBottom="8dp">
            <com.google.android.material.card.MaterialCardView android:id="@+id/btn_touch" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#00000000" app:cardCornerRadius="16dp" app:strokeColor="#D500F9" app:strokeWidth="2dp" app:cardElevation="0dp">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="TOUCH" android:textColor="#D500F9" android:textStyle="bold" android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:id="@+id/btn_fps" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#00000000" app:cardCornerRadius="16dp" app:strokeColor="#00E676" app:strokeWidth="2dp" app:cardElevation="0dp">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="FPS MAX" android:textColor="#00E676" android:textStyle="bold" android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <com.google.android.material.card.MaterialCardView android:id="@+id/btn_sistema" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#00000000" app:cardCornerRadius="16dp" app:strokeColor="#FFEA00" app:strokeWidth="2dp" app:cardElevation="0dp">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="SISTEMA" android:textColor="#FFEA00" android:textStyle="bold" android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:id="@+id/btn_zram" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#00000000" app:cardCornerRadius="16dp" app:strokeColor="#FFFFFF" app:strokeWidth="2dp" app:cardElevation="0dp">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="ZRAM" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="10"
        android:text="MORAES YAROSNI // VIP 2026"
        android:textColor="#888888"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center" />

</LinearLayout>
