<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#10121A"> <View
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:background="#1AFFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardBackgroundColor="#1A000000"
            app:cardCornerRadius="35dp"
            app:strokeColor="#C0C0C0"
            app:strokeWidth="8dp"
            app:cardElevation="15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CORETUNER MAX // ULTRA VIP"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="20dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="170dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:cardCornerRadius="25dp"
                    app:strokeColor="#FFFFFF"
                    app:strokeWidth="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/txt_shizuku"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="> SHIZUKU VINCULADO COM SUCESSO <"
                            android:textColor="#00FF41"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txt_cpu_speed"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="1,35 GHz"
                            android:textColor="#FFFFFF"
                            android:textSize="68sp"
                            android:textStyle="bold"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_ajuste_fino"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_margin="6dp"
                        android:text="AJUSTE\nFINO"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        app:backgroundTint="#4DFFFFFF"
                        app:strokeColor="#FF1744"
                        app:strokeWidth="6dp"
                        app:cornerRadius="25dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_economia"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_margin="6dp"
                        android:text="ECONOMIA"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        app:backgroundTint="#4DFFFFFF"
                        app:strokeColor="#00FF41"
                        app:strokeWidth="6dp"
                        app:cornerRadius="25dp" />
                </LinearLayout>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:layout_marginTop="10dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_performance"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:text="PERF"
                        app:backgroundTint="#4DFFFFFF"
                        app:strokeColor="#FF9100"
                        app:strokeWidth="5dp"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_bateria"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:text="BATERIA"
                        app:backgroundTint="#4DFFFFFF"
                        app:strokeColor="#00B0FF"
                        app:strokeWidth="5dp"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_touch"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:text="TOUCH"
                        app:backgroundTint="#4DFFFFFF"
                        app:strokeColor="#D500F9"
                        app:strokeWidth="5dp"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_fps"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:text="FPS"
                        app:backgroundTint="#4DFFFFFF"
                        app:strokeColor="#00FF8C"
                        app:strokeWidth="5dp"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_sistema"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:text="SYSTEM"
                        app:backgroundTint="#4DFFFFFF"
                        app:strokeColor="#FFEA00"
                        app:strokeWidth="5dp"
                        app:cornerRadius="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_zram"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="5dp"
                        android:text="ZRAM"
                        app:backgroundTint="#4DFFFFFF"
                        app:strokeColor="#FFFFFF"
                        app:strokeWidth="5dp"
                        app:cornerRadius="20dp" />
                </GridLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MORAES YAROSNI // VIP 2026"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </ScrollView>
</FrameLayout>
