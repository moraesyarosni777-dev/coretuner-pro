<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0B0D">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/brushed_steel_bg"
        android:alpha="0.4"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CORETUNER PRO MAX // VIP"
            android:textColor="#00E5FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:shadowColor="#00E5FF"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="10" />

        <androidx.cardview.widget.CardView
            android:id="@+id/mainCard"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#CC1A2530"
            app:cardElevation="15dp">
            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="15dp">

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AGUARDANDO INJEÇÃO..."
                    android:textColor="#32CD32"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:orientation="horizontal">
                    
                    <TextView
                        android:id="@+id/coreValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.00"
                        android:textColor="#00FF41"
                        android:textSize="50sp"
                        android:fontFamily="monospace" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GHz"
                        android:textColor="#00FF41"
                        android:layout_marginLeft="5dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/ramValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:text="RAM_LOAD: 0%"
                    android:textColor="#D500F9"
                    android:fontFamily="monospace" />
                    
                <TextView
                    android:id="@+id/dtcValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentRight="true"
                    android:text="DTC: 0.00"
                    android:textColor="#AA00FF"
                    android:fontFamily="monospace" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:columnCount="2"
            android:alignmentMode="alignMargins">

            <Button
                android:id="@+id/performanceButton"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="OTIMIZAR\nEXTREMO ⚡"
                android:backgroundTint="#2E1A1A"
                android:textColor="#FF5722"
                android:textStyle="bold" />

            <Button
                android:id="@+id/batteryButton"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="ECONOMIA\nFRIO ❄️"
                android:backgroundTint="#1A2E35"
                android:textColor="#00BCD4"
                android:textStyle="bold" />

            <Button
                android:id="@+id/cacheButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="LIMPAR CACHE"
                android:backgroundTint="#0A1A0A"
                android:textColor="#32CD32" />

            <Button
                android:id="@+id/touchButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="TOUCH OPTIM"
                android:backgroundTint="#1A0A1A"
                android:textColor="#D500F9" />
        </GridLayout>

        <TextView
            android:id="@+id/signature3D"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="40dp"
            android:text="Moraes Yarosni VIP"
            android:textColor="#32CD32"
            android:textSize="18sp"
            android:textStyle="italic" />

    </LinearLayout>
</RelativeLayout>
