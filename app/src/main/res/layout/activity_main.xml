<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0B0D">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/brushed_steel_bg"
        android:alpha="0.8" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#CC10151A"
        app:tabTextColor="#66FFFFFF"
        app:tabSelectedTextColor="#00E5FF"
        app:tabIndicatorColor="#00E5FF" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tabLayout"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CORETUNER PRO MAX // VIP"
            android:textColor="#00E5FF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mainCard"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="15dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#BB0D1117"
            app:strokeColor="#4400FF41"
            app:strokeWidth="2dp"
            app:cardElevation="30dp">
            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="20dp">

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="> STATUS: OFFLINE"
                    android:textColor="#FF0000"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/coreValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="0.00 GHz"
                    android:textColor="#00FF41"
                    android:textSize="38sp"
                    android:fontFamily="monospace"
                    android:shadowColor="#00FF41"
                    android:shadowRadius="10" />

                <TextView
                    android:id="@+id/ramValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:text="MEM: 0%"
                    android:textColor="#D500F9"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/dtcValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentRight="true"
                    android:text="DTC: 0.00"
                    android:textColor="#AA00FF"
                    android:fontFamily="monospace" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/performanceButton"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="EXTREMO ⚡"
                app:backgroundTint="#1A1F26"
                android:textColor="#FF5722"
                app:cornerRadius="15dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/batteryButton"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:text="FRIO ❄️"
                app:backgroundTint="#1A1F26"
                android:textColor="#00BCD4"
                app:cornerRadius="15dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cacheButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_margin="5dp"
            android:text="LIMPAR CACHE"
            app:backgroundTint="#0F1F0F"
            android:textColor="#32CD32" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/touchButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_margin="5dp"
            android:text="OTIMIZAR TOUCH"
            app:backgroundTint="#1F0F1F"
            android:textColor="#D500F9" />

        <TextView
            android:id="@+id/signature3D"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="Moraes Yarosni VIP"
            android:textColor="#32CD32"
            android:textStyle="italic"
            android:textSize="18sp" />
    </LinearLayout>
</RelativeLayout>
