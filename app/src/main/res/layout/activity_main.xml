<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#120A1A">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_purple_dark"
        android:alpha="0.9" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CORETUNER MAX // VIP"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mainCard"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="15dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#CC0D1117"
            app:strokeColor="#6600FF41"
            app:strokeWidth="2dp"
            app:cardElevation="30dp">
            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="20dp">

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="> STATUS: SYSTEM_ONLINE"
                    android:textColor="#32CD32"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/coreValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="0.00 GHz"
                    android:textColor="#00FF41"
                    android:textSize="40sp"
                    android:fontFamily="monospace"
                    android:shadowColor="#00FF41"
                    android:shadowRadius="15" />

                <TextView
                    android:id="@+id/ramValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:text="RAM_LOAD: 0%"
                    android:textColor="#D500F9"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/dtcValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentRight="true"
                    android:layout_alignParentEnd="true"
                    android:text="DTC: 0.00"
                    android:textColor="#00E5FF"
                    android:fontFamily="monospace" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="> Ajuste Fino - Resultado Instantâneo"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:columnCount="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/performanceButton"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="EXTREMO ⚡"
                app:backgroundTint="#1A1F26"
                android:textColor="#FF5722"
                app:cornerRadius="15dp"
                app:strokeWidth="2dp"
                app:strokeColor="#FF5722"
                app:elevation="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/batteryButton"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="FRIO ❄️"
                app:backgroundTint="#1A1F26"
                android:textColor="#00BCD4"
                app:cornerRadius="15dp"
                app:strokeWidth="2dp"
                app:strokeColor="#00BCD4"
                app:elevation="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/touchButton"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="TOUCH 👆"
                app:backgroundTint="#1A1F26"
                android:textColor="#D500F9"
                app:cornerRadius="15dp"
                app:strokeWidth="2dp"
                app:strokeColor="#D500F9"
                app:elevation="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/fpsButton"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="FPS MAX 📺"
                app:backgroundTint="#1A1F26"
                android:textColor="#00FF41"
                app:cornerRadius="15dp"
                app:strokeWidth="2dp"
                app:strokeColor="#00FF41"
                app:elevation="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/systemButton"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="SISTEMA 🧠"
                app:backgroundTint="#1A1F26"
                android:textColor="#FFC107"
                app:cornerRadius="15dp"
                app:strokeWidth="2dp"
                app:strokeColor="#FFC107"
                app:elevation="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/zramButton"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="5dp"
                android:text="ZRAM/MEM 💾"
                app:backgroundTint="#1A1F26"
                android:textColor="#673AB7"
                app:cornerRadius="15dp"
                app:strokeWidth="2dp"
                app:strokeColor="#673AB7"
                app:elevation="8dp"/>
        </GridLayout>

        <TextView
            android:id="@+id/signature3D"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="Moraes Yarosni VIP"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="italic"
            android:elevation="30dp"
            android:shadowColor="#FFFFFF"
            android:shadowRadius="10"/>

    </LinearLayout>
</FrameLayout>
