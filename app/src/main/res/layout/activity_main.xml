<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_white_3d">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="#FFFFFF"
        app:tabTextColor="#757575"
        app:tabSelectedTextColor="#D500F9"
        app:tabIndicatorColor="#D500F9"
        android:elevation="10dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tabLayout"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CORETUNER MAX // VIP"
                android:textColor="#1A1A1A"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginTop="5dp"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mainCard"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="15dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#1A1A1A"
                app:strokeWidth="3dp"
                app:cardElevation="25dp"
                android:translationZ="10dp">
                
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="> STATUS: SYSTEM_ONLINE"
                        android:textColor="#00C853"
                        android:fontFamily="monospace"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/coreValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text="0.00 GHz"
                        android:textColor="#00C853"
                        android:textSize="40sp"
                        android:fontFamily="monospace"
                        android:shadowColor="#4400C853"
                        android:shadowRadius="10" />

                    <TextView
                        android:id="@+id/ramValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:text="RAM_LOAD: 0%"
                        android:textColor="#AA00FF"
                        android:fontFamily="monospace"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/dtcValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentRight="true"
                        android:layout_alignParentEnd="true"
                        android:text="DTC: 0.00"
                        android:textColor="#00B0FF"
                        android:fontFamily="monospace"
                        android:textStyle="bold" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="> Ajuste Fino - Resultado Instantâneo"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:columnCount="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/performanceButton"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:text="EXTREMO ⚡"
                    app:backgroundTint="#FFFFFF"
                    android:textColor="#FF3D00"
                    app:cornerRadius="15dp"
                    app:strokeWidth="3dp"
                    app:strokeColor="#FF3D00"
                    app:elevation="12dp"
                    android:translationZ="5dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/batteryButton"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:text="FRIO ❄️"
                    app:backgroundTint="#FFFFFF"
                    android:textColor="#00B0FF"
                    app:cornerRadius="15dp"
                    app:strokeWidth="3dp"
                    app:strokeColor="#00B0FF"
                    app:elevation="12dp"
                    android:translationZ="5dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/touchButton"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:text="TOUCH 👆"
                    app:backgroundTint="#FFFFFF"
                    android:textColor="#D500F9"
                    app:cornerRadius="15dp"
                    app:strokeWidth="3dp"
                    app:strokeColor="#D500F9"
                    app:elevation="12dp"
                    android:translationZ="5dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fpsButton"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:text="FPS MAX 📺"
                    app:backgroundTint="#FFFFFF"
                    android:textColor="#00E676"
                    app:cornerRadius="15dp"
                    app:strokeWidth="3dp"
                    app:strokeColor="#00E676"
                    app:elevation="12dp"
                    android:translationZ="5dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/systemButton"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:text="SISTEMA 🧠"
                    app:backgroundTint="#FFFFFF"
                    android:textColor="#FFC107"
                    app:cornerRadius="15dp"
                    app:strokeWidth="3dp"
                    app:strokeColor="#FFC107"
                    app:elevation="12dp"
                    android:translationZ="5dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/zramButton"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="5dp"
                    android:text="ZRAM/MEM 💾"
                    app:backgroundTint="#FFFFFF"
                    android:textColor="#651FFF"
                    app:cornerRadius="15dp"
                    app:strokeWidth="3dp"
                    app:strokeColor="#651FFF"
                    app:elevation="12dp"
                    android:translationZ="5dp"/>
            </GridLayout>

            <TextView
                android:id="@+id/signature3D"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="30dp"
                android:gravity="center"
                android:text="Moraes Yarosni VIP"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:elevation="30dp"
                android:shadowColor="#000000"
                android:shadowRadius="20"
                android:shadowDx="3"
                android:shadowDy="3" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout
