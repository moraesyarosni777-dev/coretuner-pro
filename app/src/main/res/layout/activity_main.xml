<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0B0D">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/brushed_steel_bg"
        android:alpha="0.5"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CORETUNER PRO MAX // VIP"
            android:textColor="#00E5FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <androidx.cardview.widget.CardView
            android:id="@+id/mainCard"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="15dp"
            app:cardBackgroundColor="#CC10151A"
            app:cardElevation="10dp">
            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="15dp">

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SISTEMA: AGUARDANDO"
                    android:textColor="#32CD32"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/coreValueText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="0.00 GHz"
                    android:textColor="#00FF41"
                    android:textSize="35sp"
                    android:fontFamily="monospace" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:orientation="horizontal">
                    
                    <TextView
                        android:id="@+id/ramValueText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="RAM: 0%"
                        android:textColor="#D500F9"
                        android:fontFamily="monospace" />
                        
                    <TextView
                        android:id="@+id/dtcValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DTC: 0.00"
                        android:textColor="#AA00FF"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MÓDULOS DE INJEÇÃO"
            android:textColor="#446688"
            android:textSize="10sp"
            android:layout_marginTop="25dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:columnCount="2"
            android:alignmentMode="alignMargins">

            <Button
                android:id="@+id/performanceButton"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="EXTREMO ⚡"
                android:backgroundTint="#1A1F26"
                android:textColor="#FF5722" />

            <Button
                android:id="@+id/batteryButton"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="FRIO ❄️"
                android:backgroundTint="#1A1F26"
                android:textColor="#00BCD4" />

            <Button
                android:id="@+id/cacheButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="PURGE"
                android:backgroundTint="#0F1F0F"
                android:textColor="#32CD32" />

            <Button
                android:id="@+id/touchButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:text="TOUCH"
                android:backgroundTint="#1F0F1F"
                android:textColor="#D500F9" />
        </GridLayout>

        <TextView
            android:id="@+id/signature3D"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center"
            android:text="Moraes Yarosni VIP"
            android:textColor="#32CD32"
            android:textSize="16sp"
            android:textStyle="italic" />

    </LinearLayout>
</RelativeLayout
