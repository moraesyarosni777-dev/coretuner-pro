<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F141E"
    android:padding="16dp"
    android:weightSum="100">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="8"
        android:text="CORETUNER MAX // ULTRA VIP"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="24"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#0A000000"
        app:cardCornerRadius="24dp"
        app:strokeColor="#FFFDD0" 
        app:strokeWidth="4dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="12dp">

            <TextView
                android:id="@+id/txt_shizuku"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SHIZUKU VINCULADO COM SUCESSO"
                android:textColor="#39FF14"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/txt_cpu_speed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AO CLICAR NAS CONFIGURAÇÕES ABAIXO LIMITADORES DE HARDWARE SERÃO DESATIVADOS ATIVANDO EFEITOS IMEDIATOS"
                android:textColor="#FFFACD" 
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="16"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_ajuste_fino"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#0AFF1744"
            app:cardCornerRadius="16dp"
            app:strokeColor="#B3FF1744"
            app:strokeWidth="3dp"
            app:cardElevation="0dp">

            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="AJUSTE FINO" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_economia"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#0A00FF41"
            app:cardCornerRadius="16dp"
            app:strokeColor="#B300FF41"
            app:strokeWidth="3dp"
            app:cardElevation="0dp">

            <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="ECONOMIA" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="42"
        android:orientation="vertical"
        android:weightSum="3">

        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:layout_marginBottom="6dp">
            <com.google.android.material.card.MaterialCardView android:id="@+id/btn_performance" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#0AFF9100" app:cardCornerRadius="16dp" app:strokeColor="#B3FF9100" app:strokeWidth="2dp" app:cardElevation="0dp">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="PERFORMANCE" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/btn_bateria" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#0A2979FF" app:cardCornerRadius="16dp" app:strokeColor="#B32979FF" app:strokeWidth="2dp" app:cardElevation="0dp">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="BATERIA" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:layout_marginBottom="6dp">
            <com.google.android.material.card.MaterialCardView android:id="@+id/btn_touch" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#0AD500F9" app:cardCornerRadius="16dp" app:strokeColor="#B3D500F9" app:strokeWidth="2dp" app:cardElevation="0dp">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="TOUCH" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/btn_fps" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#0A00E676" app:cardCornerRadius="16dp" app:strokeColor="#B300E676" app:strokeWidth="2dp" app:cardElevation="0dp">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="FPS MAX" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <com.google.android.material.card.MaterialCardView android:id="@+id/btn_sistema" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#0AFFEA00" app:cardCornerRadius="16dp" app:strokeColor="#B3FFEA00" app:strokeWidth="2dp" app:cardElevation="0dp">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="SISTEMA" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/btn_zram" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#0A00B0FF" app:cardCornerRadius="16dp" app:strokeColor="#B300B0FF" app:strokeWidth="2dp" app:cardElevation="0dp">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="ZRAM" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="10"
        android:text="MORAES YAROSNI // VIP 2026&#10;by Yarosni"
        android:textColor="#39FF14"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center" />

</LinearLayout>
