<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050508"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CORETUNER MAX // ULTRA VIP"
            android:textAlignment="center"
            android:textColor="#50E3C2"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#0F0F14"
            app:cardCornerRadius="14dp"
            app:cardElevation="8dp"
            app:strokeColor="#6A1B9A"
            app:strokeWidth="1.2dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SISTEMA VINCULADO: MODO VIP"
                    android:textColor="#BC6AFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATUS: MODO ORIGINAL"
                    android:textColor="#666666"
                    android:textSize="11sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#251A35"
                    android:layout_marginVertical="12dp"/>

                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="1,3">
                    <TableRow>
                        <TextView android:text="DATA" android:textColor="#444444" android:textSize="10sp" android:paddingEnd="8dp"/>
                        <TextView android:id="@+id/txt_data" android:text="1.30" android:textColor="#32FF7E" android:textSize="11sp" android:textStyle="bold"/>
                        <TextView android:text="ATU:" android:textColor="#444444" android:textSize="10sp" android:paddingStart="16dp" android:paddingEnd="8dp"/>
                        <TextView android:id="@+id/txt_atu" android:text="53.57 MHz" android:textColor="#32FF7E" android:textSize="11sp" android:textStyle="bold"/>
                    </TableRow>
                    <TableRow android:layout_marginTop="6dp">
                        <TextView android:text="UPI:" android:textColor="#444444" android:textSize="10sp" android:paddingEnd="8dp"/>
                        <TextView android:id="@+id/txt_upi" android:text="25.03" android:textColor="#32FF7E" android:textSize="11sp" android:textStyle="bold"/>
                        <TextView android:text="BPG:" android:textColor="#444444" android:textSize="10sp" android:paddingStart="16dp" android:paddingEnd="8dp"/>
                        <TextView android:id="@+id/txt_bpg" android:text="38.05 MHs" android:textColor="#32FF7E" android:textSize="11sp" android:textStyle="bold"/>
                    </TableRow>
                </TableLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_ajuste"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                app:cardBackgroundColor="#0D0D12"
                app:cardCornerRadius="10dp"
                app:strokeColor="#1F1F26"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_menu_preferences"
                        app:tint="#C084FC" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AJUSTE FINO"
                        android:textColor="#C084FC"
                        android:layout_marginTop="8dp"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MORAES YAROSNI // VIP 2026\nby Yarosni"
            android:textAlignment="center"
            android:textColor="#333333"
            android:textSize="10sp"
            android:layout_marginTop="30dp" />

    </LinearLayout>
</ScrollView>
