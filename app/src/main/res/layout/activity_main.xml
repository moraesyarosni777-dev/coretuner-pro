<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ESTADO SELECIONADO: Neon Ciano Ativo com Camadas de Brilho -->
    <item android:state_selected="true">
        <layer-list>
            <!-- Nível 1: Base com Múltiplos Gradientes para Metal Escovado (Obsidiana) -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <gradient
                        android:startColor="#1A1A22"
                        android:centerColor="#0C0C10"
                        android:endColor="#14141A"
                        android:type="linear"
                        android:angle="135" />
                </shape>
            </item>

            <!-- Nível 2: Múltiplos Outer Glows (Brilho Neon Ciano Suave) - Simula o "Glow" -->
            <item android:top="-12dp" android:bottom="-12dp" android:left="-12dp" android:right="-12dp">
                <shape android:shape="rectangle">
                    <corners android:radius="26dp" />
                    <gradient
                        android:startColor="#205BF0FE"
                        android:centerColor="#055BF0FE"
                        android:endColor="#005BF0FE"
                        android:type="linear"
                        android:angle="90" />
                </shape>
            </item>
             <item android:top="-6dp" android:bottom="-6dp" android:left="-6dp" android:right="-6dp">
                <shape android:shape="rectangle">
                    <corners android:radius="20dp" />
                    <gradient
                        android:startColor="#605BF0FE"
                        android:centerColor="#205BF0FE"
                        android:endColor="#005BF0FE"
                        android:type="linear"
                        android:angle="90" />
                </shape>
            </item>

            <!-- Nível 3: Borda Neon Ciano Rígida e Brilhante (2dp) -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <stroke
                        android:width="2dp"
                        android:color="#5BF0FE" />
                </shape>
            </item>

            <!-- Nível 4: Brilho Interno Ciano Suave (1dp) com Offset -->
            <item android:insetLeft="2dp" android:insetTop="2dp" android:insetRight="2dp" android:insetBottom="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <gradient
                        android:startColor="#405BF0FE"
                        android:endColor="#005BF0FE"
                        android:type="linear"
                        android:angle="90" />
                </shape>
            </item>

        </layer-list>
    </item>


    <!-- ESTADO PADRÃO: Obsidiana Stealth com Sombra Interna e Borda Fina -->
    <item>
        <layer-list>
            <!-- Nível 1: Base de Fundo Profundo -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#0D0D12" />
                </shape>
            </item>

            <!-- Nível 2: Sombra Interna Falsa (Offset Superior-Esquerdo) -->
            <item android:insetLeft="-2dp" android:insetTop="-2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <gradient
                        android:startColor="#F00A0A10"
                        android:endColor="#000A0A10"
                        android:type="linear"
                        android:angle="135" />
                </shape>
            </item>

            <!-- Nível 3: Borda Stealth Dark (2dp) - Degradê sutil de roxo para ciano -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <stroke
                        android:width="2dp"
                        android:color="#1F1F26" />
                </shape>
            </item>

        </layer-list>
    </item>
</selector>
