<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0C121E"
    android:padding="6dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardBackgroundColor="#0C121E"
        app:cardCornerRadius="24dp"
        app:strokeColor="#A98242"
        app:strokeWidth="10dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="18dp"
            android:weightSum="100">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="8"
                android:text="CORETUNER MAX // ULTRA VIP"
                android:textColor="#00E5FF"
                android:shadowColor="#00E5FF"
                android:shadowRadius="15.0"
                android:shadowDx="0.0"
                android:shadowDy="0.0"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="24"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#0A00E676"
                app:cardCornerRadius="20dp"
                app:strokeColor="#00E676"
                app:strokeWidth="8dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/txt_shizuku"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SHIZUKU VINCULADO COM SUCESSO"
                        android:textColor="#00E676"
                        android:shadowColor="#00E676"
                        android:shadowRadius="15.0"
                        android:shadowDx="0.0"
                        android:shadowDy="0.0"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/txt_cpu_speed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="AO CLICAR NAS CONFIGURAÇÕES&#10;ABAIXO LIMITADORES DE&#10;HARDWARE SERÃO DESATIVADOS&#10;ATIVANDO EFEITOS IMEDIATOS"
                        android:textColor="#00E5FF"
                        android:shadowColor="#00E5FF"
                        android:shadowRadius="15.0"
                        android:shadowDx="0.0"
                        android:shadowDy="0.0"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="16"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_ajuste_fino"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#0A00E5FF"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="#00E5FF"
                    app:strokeWidth="8dp"
                    app:cardElevation="0dp">
                    
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛠️" android:textSize="34sp" android:layout_marginEnd="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AJUSTE FINO" android:textColor="#00E5FF" android:shadowColor="#00E5FF" android:shadowRadius="15.0" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_economia"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#0A00E5FF"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="#00E5FF"
                    app:strokeWidth="8dp"
                    app:cardElevation="0dp">
                    
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center" android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📉" android:textSize="34sp" android:layout_marginEnd="8dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ECONOMIA" android:textColor="#00E5FF" android:shadowColor="#00E5FF" android:shadowRadius="15.0" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="42"
                android:orientation="vertical"
                android:weightSum="3">

                <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <com.google.android.material.card.MaterialCardView android:id="@+id/btn_performance" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#0A00E676" app:cardCornerRadius="16dp" app:strokeColor="#00E676" app:strokeWidth="8dp" app:cardElevation="0dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center" android:padding="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡" android:textSize="34sp" android:layout_marginEnd="8dp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PERFORMANCE" android:textColor="#00E676" android:shadowColor="#00E676" android:shadowRadius="15.0" android:textSize="13sp" android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                    <com.google.android.material.card.MaterialCardView android:id="@+id/btn_bateria" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#0A00E676" app:cardCornerRadius="16dp" app:strokeColor="#00E676" app:strokeWidth="8dp" app:cardElevation="0dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center" android:padding="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔋" android:textSize="34sp" android:layout_marginEnd="8dp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BATERIA" android:textColor="#00E676" android:shadowColor="#00E676" android:shadowRadius="15.0" android:textSize="13sp" android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <com.google.android.material.card.MaterialCardView android:id="@+id/btn_touch" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#0A00E676" app:cardCornerRadius="16dp" app:strokeColor="#00E676" app:strokeWidth="8dp" app:cardElevation="0dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center" android:padding="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👆" android:textSize="34sp" android:layout_marginEnd="8dp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOUCH" android:textColor="#00E676" android:shadowColor="#00E676" android:shadowRadius="15.0" android:textSize="13sp" android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                    <com.google.android.material.card.MaterialCardView android:id="@+id/btn_fps" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#0A00E676" app:cardCornerRadius="16dp" app:strokeColor="#00E676" app:strokeWidth="8dp" app:cardElevation="0dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center" android:padding="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎮" android:textSize="34sp" android:layout_marginEnd="8dp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FPS MAX" android:textColor="#00E676" android:shadowColor="#00E676" android:shadowRadius="15.0" android:textSize="13sp" android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
                    <com.google.android.material.card.MaterialCardView android:id="@+id/btn_sistema" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#0A00E676" app:cardCornerRadius="16dp" app:strokeColor="#00E676" app:strokeWidth="8dp" app:cardElevation="0dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center" android:padding="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🖥️" android:textSize="34sp" android:layout_marginEnd="8dp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SISTEMA" android:textColor="#00E676" android:shadowColor="#00E676" android:shadowRadius="15.0" android:textSize="13sp" android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                    <com.google.android.material.card.MaterialCardView android:id="@+id/btn_zram" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="6dp" android:clickable="true" android:focusable="true" app:cardBackgroundColor="#0A00E676" app:cardCornerRadius="16dp" app:strokeColor="#00E676" app:strokeWidth="8dp" app:cardElevation="0dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center" android:padding="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧠" android:textSize="34sp" android:layout_marginEnd="8dp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ZRAM" android:textColor="#00E676" android:shadowColor="#00E676" android:shadowRadius="15.0" android:textSize="13sp" android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="10"
                android:text="MORAES YAROSNI // VIP 2026&#10;by Yarosni"
                android:textColor="#00E5FF"
                android:shadowColor="#00E5FF"
                android:shadowRadius="15.0"
                android:shadowDx="0.0"
                android:shadowDy="0.0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
