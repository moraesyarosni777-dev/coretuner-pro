<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_glass_deep"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_outer_frame"
        android:padding="20dp">

        <TextView
            style="@style/NeonTextCyan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="CORETUNER MAX // ULTRA VIP"
            android:textSize="18sp"
            android:layout_marginBottom="24dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_panel_shizuku"
            android:padding="20dp"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <TextView
                style="@style/NeonTextGreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SHIZUKU VINCULADO COM SUCESSO"
                android:layout_marginBottom="8dp"/>

            <TextView
                style="@style/NeonTextCyan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AO CLICAR NAS CONFIGURAÇÕES\nABAIXO LIMITADORES DE\nHARDWARE SERÃO DESATIVADOS\nATIVANDO EFEITOS IMEDIATOS"
                android:textAlignment="center"
                android:textSize="12sp"/>
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:useDefaultMargins="true">

            <!-- 1 Ajuste Fino -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/bg_item_cyan"
                android:gravity="center"
                android:orientation="horizontal">
                <!-- O ImageView está vazio, depois você baixa os emojis 3D do GitHub e coloca a referência deles aqui no src -->
                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_marginEnd="8dp"/>
                <TextView style="@style/NeonTextCyan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AJUSTE FINO"/>
            </LinearLayout>

            <!-- 2 Economia -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/bg_item_cyan"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_marginEnd="8dp"/>
                <TextView style="@style/NeonTextCyan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ECONOMIA"/>
            </LinearLayout>

            <!-- 3 Performance -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/bg_item_green"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_marginEnd="8dp"/>
                <TextView style="@style/NeonTextGreen" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PERFORMANCE"/>
            </LinearLayout>

            <!-- 4 Bateria -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/bg_item_green"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_marginEnd="8dp"/>
                <TextView style="@style/NeonTextGreen" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BATERIA"/>
            </LinearLayout>

            <!-- 5 Touch -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/bg_item_green"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_marginEnd="8dp"/>
                <TextView style="@style/NeonTextGreen" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TOUCH"/>
            </LinearLayout>

            <!-- 6 FPS MAX -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/bg_item_green"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_marginEnd="8dp"/>
                <TextView style="@style/NeonTextGreen" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FPS MAX"/>
            </LinearLayout>

            <!-- 7 Sistema -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/bg_item_cyan"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_marginEnd="8dp"/>
                <TextView style="@style/NeonTextCyan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SISTEMA"/>
            </LinearLayout>

            <!-- 8 ZRAM -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/bg_item_cyan"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView android:layout_width="32dp" android:layout_height="32dp" android:layout_marginEnd="8dp"/>
                <TextView style="@style/NeonTextCyan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ZRAM"/>
            </LinearLayout>

        </GridLayout>

        <TextView
            style="@style/NeonTextCyan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="30dp"
            android:text="MORAES YAROSNI // VIP 2026\nby Yarosni"
            android:textAlignment="center"
            android:textSize="14sp"/>

    </LinearLayout>
</ScrollView>
