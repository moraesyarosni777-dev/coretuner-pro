<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/brushed_steel_bg">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="#9910151A" 
        app:tabTextColor="#FFFFFF"
        app:tabSelectedTextColor="#00E5FF"
        app:tabIndicatorColor="#00E5FF"
        android:elevation="10dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tabLayout"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/dateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Data / Hora VIP"
                android:textColor="#446688"
                android:textSize="12sp"
                android:layout_marginTop="10dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mainCard"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#CC1A2530"
                app:strokeColor="#3300E5FF"
                app:strokeWidth="1dp"
                app:cardElevation="20dp">
                
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="15dp">

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AGUARDANDO INJEÇÃO..."
                        android:textColor="#32CD32"
                        android:fontFamily="monospace"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/spectrumView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_centerInParent="true"
                        android:src="@android:drawable/ic_dialog_map"
                        android:alpha="0.2"
                        android:scaleType="centerCrop" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/coreValueText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.00"
                            android:textColor="#00FF41"
                            android:textSize="48sp"
                            android:fontFamily="monospace" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GHz"
                            android:textColor="#00FF41"
                            android:layout_marginLeft="5dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/ramValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:text="RAM_LOAD: 0%"
                        android:textColor="#D500F9"
                        android:fontFamily="monospace" />
                        
                    <TextView
                        android:id="@+id/dtcValueText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentRight="true"
                        android:text="DTC: 0.00"
                        android:textColor="#AA00FF"
                        android:fontFamily="monospace" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:columnCount="2"
                android:alignmentMode="alignMargins">

                <Button
                    android:id="@+id/performanceButton"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="EXTREMO\n⚡"
                    android:backgroundTint="#2E1A1A"
                    android:textColor="#FF5722"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/batteryButton"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="ECONOMIA\n❄️🔋"
                    android:backgroundTint="#1A2E35"
                    android:textColor="#00BCD4"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/cacheButton"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="LIMPAR CACHE"
                    android:backgroundTint="#0F1F0F"
                    android:textColor="#32CD32"/>

                <Button
                    android:id="@+id/touchButton"
                    android:layout_width="0dp"
                    android:layout_height="65dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="6dp"
                    android:text="TOUCH"
                    android:backgroundTint="#1F0F1F"
                    android:textColor="#D500F9"/>
            </GridLayout>

            <TextView
                android:id="@+id/signature3D"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="35dp"
                android:gravity="center"
                android:text="Moraes Yarosni"
                android:textColor="#32CD32"
                android:textSize="20sp"
                android:textStyle="italic"
                android:elevation="15dp" />
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
