<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F14">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="CoreTuner Pro MAX VIP"
        android:textColor="#00E5FF"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HARDCORE TUNING • BRUTAL PERFORMANCE"
        android:textColor="#607D8B"
        android:textSize="10sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleText" />

    <androidx.cardview.widget.CardView
        android:id="@+id/terminalCard"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#051405"
        app:cardCornerRadius="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitleText">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/dateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOADING DATA..."
                android:textColor="#2E7D32"
                android:textSize="10sp"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="** AJUSTE FINO • RESULTADO INSTANTÂNEO **\nAGUARDANDO INJEÇÃO..."
                android:textColor="#00FF00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1B5E20" android:layout_marginVertical="10dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="60dp" android:layout_height="wrap_content" android:text="CORE:" android:textColor="#32CD32" android:fontFamily="monospace"/>
                <TextView android:id="@+id/coreValueText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.00" android:textColor="#00FF00" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="60dp" android:layout_height="wrap_content" android:text="DTC:" android:textColor="#32CD32" android:fontFamily="monospace"/>
                <TextView android:id="@+id/dtcValueText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.00" android:textColor="#00FF00" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="60dp" android:layout_height="wrap_content" android:text="RAM:" android:textColor="#32CD32" android:fontFamily="monospace"/>
                <TextView android:id="@+id/ramValueText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textColor="#00FF00" android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/terminalCard">

        <Button android:id="@+id/touchButton" android:layout_width="match_parent" android:layout_height="55dp" android:text="Otimizar Touch" android:layout_marginBottom="8dp" android:backgroundTint="#1A237E"/>
        <Button android:id="@+id/performanceButton" android:layout_width="match_parent" android:layout_height="55dp" android:text="Turbo RAM / LMK" android:layout_marginBottom="8dp" android:backgroundTint="#311B92"/>
        <Button android:id="@+id/cacheButton" android:layout_width="match_parent" android:layout_height="55dp" android:text="Limpar Cache" android:layout_marginBottom="8dp" android:backgroundTint="#1B5E20"/>
        <Button android:id="@+id/batteryButton" android:layout_width="match_parent" android:layout_height="55dp" android:text="Forçar 120Hz" android:backgroundTint="#BF360C"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView android:id="@+id/mainCard" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" tools:ignore="MissingConstraints" />
    <com.google.android.material.tabs.TabLayout android:id="@+id/tabLayout" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" tools:ignore="MissingConstraints" />
    <ImageView android:id="@+id/spectrumView" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" tools:ignore="MissingConstraints" />
    <TextView android:id="@+id/signature3D" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" tools:ignore="MissingConstraints" />

</androidx.constraintlayout.widget.ConstraintLayout>
